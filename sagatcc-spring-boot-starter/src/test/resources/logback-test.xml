<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Expected rollback paths are asserted by tests; keep CI output actionable. -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    <logger name="com.sagatcc.spring.messaging.OutboxPublisherJob" level="OFF"/>
    <logger name="com.sagatcc.spring.coordinator.SagaTccCoordinator" level="OFF"/>
    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
